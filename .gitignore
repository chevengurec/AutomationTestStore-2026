gitignore
# Compiled files
target/
*.class

# IDE files
.idea/
*.iml
.settings/
.project
.classpath
.vscode/

# Screenshots (локальные, не нужны в репозитории)
screenshots/

# Allure reports
allure-results/
allure-report/

# Logs
logs/
*.log

# Temporary files
*.tmp
*.bak
*.swp

# ChromeDriver
chromedriver.exe
chromedriver

# Local config (если будет)
config.local.properties